Функция SalesGet(Запрос) Экспорт

	Попытка
		ДатаСТекст = Запрос.ПараметрыЗапроса.Получить("date_from");
		ДатаПоТекст = Запрос.ПараметрыЗапроса.Получить("date_to");

		Если ПустаяСтрока(ДатаСТекст) Или ПустаяСтрока(ДатаПоТекст) Тогда
			Возврат ОтветОшибка(400, "Параметры date_from и date_to обязательны (формат YYYY-MM-DD)");
		КонецЕсли;

		ДатаНачала = XMLЗначение(Тип("Дата"), ДатаСТекст + "T00:00:00");
		ДатаОкончания = XMLЗначение(Тип("Дата"), ДатаПоТекст + "T23:59:59");
		Склад = Запрос.ПараметрыЗапроса.Получить("warehouse");

		Результат = DashboardData.ПолучитьСотув(ДатаНачала, ДатаОкончания, Склад);

		Возврат ОтветJSON(200, Результат);
	Исключение
		Возврат ОтветОшибка(500, ОписаниеОшибки());
	КонецПопытки;

КонецФункции

Функция StockGet(Запрос) Экспорт

	Попытка
		НаДатуТекст = Запрос.ПараметрыЗапроса.Получить("on_date");

		Если ПустаяСтрока(НаДатуТекст) Тогда
			НаДату = ТекущаяДатаСеанса();
		Иначе
			НаДату = XMLЗначение(Тип("Дата"), НаДатуТекст + "T23:59:59");
		КонецЕсли;

		Склад = Запрос.ПараметрыЗапроса.Получить("warehouse");
		Товар = Запрос.ПараметрыЗапроса.Получить("item");

		Результат = DashboardData.ПолучитьОстатки(НаДату, Склад, Товар);

		Возврат ОтветJSON(200, Результат);
	Исключение
		Возврат ОтветОшибка(500, ОписаниеОшибки());
	КонецПопытки;

КонецФункции

Функция FinResultGet(Запрос) Экспорт

	Попытка
		ПериодТекст = Запрос.ПараметрыЗапроса.Получить("period");

		Если ПустаяСтрока(ПериодТекст) Тогда
			Возврат ОтветОшибка(400, "Параметр period обязателен (формат YYYY-MM)");
		КонецЕсли;

		Части = СтрРазделить(ПериодТекст, "-", Истина);
		Если Части.Количество() <> 2 Тогда
			Возврат ОтветОшибка(400, "Параметр period должен быть в формате YYYY-MM");
		КонецЕсли;

		Год = Число(Части[0]);
		Месяц = Число(Части[1]);
		ДатаНачала = Дата(Год, Месяц, 1);
		ДатаОкончания = КонецМесяца(ДатаНачала);

		Результат = DashboardData.ПолучитьФинРезультат(ДатаНачала, ДатаОкончания);
		Результат.Вставить("period", ПериодТекст);

		Возврат ОтветJSON(200, Результат);
	Исключение
		Возврат ОтветОшибка(500, ОписаниеОшибки());
	КонецПопытки;

КонецФункции

