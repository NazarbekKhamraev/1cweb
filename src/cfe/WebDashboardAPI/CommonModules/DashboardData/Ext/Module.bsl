Функция ПолучитьБаланс(Знач НаДату) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.Счет.Код КАК Код,
	|	Остатки.Счет.Наименование КАК Наименование,
	|	Остатки.СуммаОстаток КАК Сумма
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&НаДату,
	|			Счет <> ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПустаяСсылка)) КАК Остатки
	|ГДЕ
	|	Остатки.СуммаОстаток <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Код";

	Запрос.УстановитьПараметр("НаДату", НаДату);

	// Субсчета (например 60.01) агрегируются к синтетическому счету (60)
	ЖамланганСчетлар = Новый Соответствие;
	ТартибСчетлар = Новый Массив;

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		КодАсосий = Лев(Выборка.Код, 2);
		Если ЖамланганСчетлар.Получить(КодАсосий) = Неопределено Тогда
			ЗаписьСчета = Новый Структура("account, name, amount", КодАсосий, Выборка.Наименование, 0);
			ЖамланганСчетлар.Вставить(КодАсосий, ЗаписьСчета);
			ТартибСчетлар.Добавить(КодАсосий);
		Иначе
			ЗаписьСчета = ЖамланганСчетлар.Получить(КодАсосий);
		КонецЕсли;
		ЗаписьСчета.amount = ЗаписьСчета.amount + Выборка.Сумма;
	КонецЦикла;

	Счета = Новый Массив;
	Для Каждого Код Из ТартибСчетлар Цикл
		Счета.Добавить(ЖамланганСчетлар.Получить(Код));
	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("on_date", Формат(НаДату, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("accounts", Счета);

	Возврат Результат;

КонецФункции

Функция ПолучитьФинРезультат(Знач ДатаНачала, Знач ДатаОкончания) Экспорт

	Выручка = 0;
	Себестоимость = 0;

	Счет90 = ПланыСчетов.Хозрасчетный.НайтиПоКоду("90");

	Если Счет90 <> Неопределено И НЕ Счет90.Пустая() Тогда

		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Обороты.Счет.Код КАК Код,
		|	Обороты.СуммаОборотДт КАК Дебет,
		|	Обороты.СуммаОборотКт КАК Кредит
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Обороты(
		|			&ДатаНачала,
		|			&ДатаОкончания,
		|			Месяц,
		|			Счет В ИЕРАРХИИ(&Счет90)) КАК Обороты";

		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
		Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		Запрос.УстановитьПараметр("Счет90", Счет90);

		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если СтрНайти(Выборка.Код, "01") > 0 Тогда
				Выручка = Выручка + Выборка.Кредит;
			ИначеЕсли СтрНайти(Выборка.Код, "02") > 0 Тогда
				Себестоимость = Себестоимость + Выборка.Дебет;
			КонецЕсли;
		КонецЦикла;

	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("revenue", Выручка);
	Результат.Вставить("cogs", Себестоимость);
	Результат.Вставить("profit", Выручка - Себестоимость);

	Возврат Результат;

КонецФункции

Функция ПолучитьБанкХаракати(Знач ДатаНачала, Знач ДатаОкончания) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Обороты.Период КАК День,
	|	Обороты.Счет.Код КАК Код,
	|	Обороты.СуммаОборотДт КАК Дебет,
	|	Обороты.СуммаОборотКт КАК Кредит
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(&ДатаНачала, &ДатаОкончания, День, ) КАК Обороты
	|
	|УПОРЯДОЧИТЬ ПО
	|	День";

	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

	// Bank/kassa hisoblari - schet kodi "50" yoki "51" bilan boshlanadi
	ПоДням = Новый Соответствие;
	ТартибКунлар = Новый Массив;
	ИтогоПриход = 0;
	ИтогоРасход = 0;

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Лев(Выборка.Код, 2) <> "50" И Лев(Выборка.Код, 2) <> "51" Тогда
			Продолжить;
		КонецЕсли;

		КлючДня = Формат(Выборка.День, "ДФ=yyyy-MM-dd");
		Если ПоДням.Получить(КлючДня) = Неопределено Тогда
			ЗаписьДня = Новый Структура("date, inflow, outflow", КлючДня, 0, 0);
			ПоДням.Вставить(КлючДня, ЗаписьДня);
			ТартибКунлар.Добавить(КлючДня);
		Иначе
			ЗаписьДня = ПоДням.Получить(КлючДня);
		КонецЕсли;

		ЗаписьДня.inflow = ЗаписьДня.inflow + Выборка.Дебет;
		ЗаписьДня.outflow = ЗаписьДня.outflow + Выборка.Кредит;
		ИтогоПриход = ИтогоПриход + Выборка.Дебет;
		ИтогоРасход = ИтогоРасход + Выборка.Кредит;
	КонецЦикла;

	Дни = Новый Массив;
	Для Каждого Ключ Из ТартибКунлар Цикл
		Дни.Добавить(ПоДням.Получить(Ключ));
	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("date_from", Формат(ДатаНачала, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("date_to", Формат(ДатаОкончания, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("total_inflow", ИтогоПриход);
	Результат.Вставить("total_outflow", ИтогоРасход);
	Результат.Вставить("days", Дни);

	Возврат Результат;

КонецФункции

Функция ПолучитьОстатки(Знач НаДату, Знач Склад = Неопределено, Знач Товар = Неопределено) Экспорт

	Остатки = Новый Массив;

	Результат = Новый Структура;
	Результат.Вставить("on_date", Формат(НаДату, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("warehouse", Склад);
	Результат.Вставить("item", Товар);
	Результат.Вставить("balances", Остатки);

	Возврат Результат;

КонецФункции
