Функция ПолучитьСотув(Знач ДатаНачала, Знач ДатаОкончания, Знач Склад = Неопределено) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(Реализация.Дата, ДЕНЬ) КАК День,
	|	СУММА(Реализация.СуммаДокумента) КАК Сумма,
	|	КОЛИЧЕСТВО(Реализация.Ссылка) КАК КоличествоДокументов
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Реализация
	|ГДЕ
	|	Реализация.Проведен = ИСТИНА
	|	И Реализация.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|
	|СГРУППИРОВАТЬ ПО
	|	НАЧАЛОПЕРИОДА(Реализация.Дата, ДЕНЬ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	День";

	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

	Дни = Новый Массив;
	ИтогоСумма = 0;

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаДня = Новый Структура;
		СтрокаДня.Вставить("date", Формат(Выборка.День, "ДФ=yyyy-MM-dd"));
		СтрокаДня.Вставить("amount", Выборка.Сумма);
		СтрокаДня.Вставить("documents", Выборка.КоличествоДокументов);
		Дни.Добавить(СтрокаДня);
		ИтогоСумма = ИтогоСумма + Выборка.Сумма;
	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("date_from", Формат(ДатаНачала, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("date_to", Формат(ДатаОкончания, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("warehouse", Склад);
	Результат.Вставить("total_amount", ИтогоСумма);
	Результат.Вставить("days", Дни);

	Возврат Результат;

КонецФункции

