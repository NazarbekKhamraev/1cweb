Функция ПолучитьБаланс(Знач НаДату) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Остатки.Счет.Код КАК Код,
	|	Остатки.Счет.Наименование КАК Наименование,
	|	Остатки.СуммаОстаток КАК Сумма
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&НаДату,
	|			Счет <> ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПустаяСсылка)) КАК Остатки
	|ГДЕ
	|	Остатки.СуммаОстаток <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Код";

	Запрос.УстановитьПараметр("НаДату", НаДату);

	// Субсчета (например 60.01) агрегируются к синтетическому счету (60)
	ЖамланганСчетлар = Новый Соответствие;
	ТартибСчетлар = Новый Массив;

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		КодАсосий = Лев(Выборка.Код, 2);
		Если ЖамланганСчетлар.Получить(КодАсосий) = Неопределено Тогда
			ЗаписьСчета = Новый Структура("account, name, amount", КодАсосий, Выборка.Наименование, 0);
			ЖамланганСчетлар.Вставить(КодАсосий, ЗаписьСчета);
			ТартибСчетлар.Добавить(КодАсосий);
		Иначе
			ЗаписьСчета = ЖамланганСчетлар.Получить(КодАсосий);
		КонецЕсли;
		ЗаписьСчета.amount = ЗаписьСчета.amount + Выборка.Сумма;
	КонецЦикла;

	Счета = Новый Массив;
	Для Каждого Код Из ТартибСчетлар Цикл
		Счета.Добавить(ЖамланганСчетлар.Получить(Код));
	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("on_date", Формат(НаДату, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("accounts", Счета);

	Возврат Результат;

КонецФункции

Функция ПолучитьФинРезультат(Знач ДатаНачала, Знач ДатаОкончания) Экспорт

	Выручка = 0;
	Себестоимость = 0;

	// РФ-стиль плана счетов: выручка/себестоимость - субсчета 90.01/90.02 одного счета "90"
	Счет90 = ПланыСчетов.Хозрасчетный.НайтиПоКоду("90");

	Если Счет90 <> Неопределено И НЕ Счет90.Пустая() Тогда

		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Обороты.Счет.Код КАК Код,
		|	Обороты.СуммаОборотДт КАК Дебет,
		|	Обороты.СуммаОборотКт КАК Кредит
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Обороты(
		|			&ДатаНачала,
		|			&ДатаОкончания,
		|			Месяц,
		|			Счет В ИЕРАРХИИ(&Счет90)) КАК Обороты";

		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
		Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		Запрос.УстановитьПараметр("Счет90", Счет90);

		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если СтрНайти(Выборка.Код, "01") > 0 Тогда
				Выручка = Выручка + Выборка.Кредит;
			ИначеЕсли СтрНайти(Выборка.Код, "02") > 0 Тогда
				Себестоимость = Себестоимость + Выборка.Дебет;
			КонецЕсли;
		КонецЦикла;

	Иначе

		// Уз НСБУ-стиль плана счетов: выручка (9000) и себестоимость (9100) - разные счета верхнего уровня
		СчетДоходы = ПланыСчетов.Хозрасчетный.НайтиПоКоду("9000");
		СчетСебестоимость = ПланыСчетов.Хозрасчетный.НайтиПоКоду("9100");

		Если СчетДоходы <> Неопределено И НЕ СчетДоходы.Пустая() Тогда
			ЗапросДоходы = Новый Запрос;
			ЗапросДоходы.Текст =
			"ВЫБРАТЬ
			|	СУММА(Обороты.СуммаОборотКт) КАК Кредит
			|ИЗ
			|	РегистрБухгалтерии.Хозрасчетный.Обороты(
			|			&ДатаНачала,
			|			&ДатаОкончания,
			|			,
			|			Счет В ИЕРАРХИИ(&Счет)) КАК Обороты";
			ЗапросДоходы.УстановитьПараметр("ДатаНачала", ДатаНачала);
			ЗапросДоходы.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
			ЗапросДоходы.УстановитьПараметр("Счет", СчетДоходы);
			ВыборкаДоходы = ЗапросДоходы.Выполнить().Выбрать();
			Если ВыборкаДоходы.Следующий() Тогда
				Выручка = ?(ВыборкаДоходы.Кредит = Неопределено, 0, ВыборкаДоходы.Кредит);
			КонецЕсли;
		КонецЕсли;

		Если СчетСебестоимость <> Неопределено И НЕ СчетСебестоимость.Пустая() Тогда
			ЗапросСебестоимость = Новый Запрос;
			ЗапросСебестоимость.Текст =
			"ВЫБРАТЬ
			|	СУММА(Обороты.СуммаОборотДт) КАК Дебет
			|ИЗ
			|	РегистрБухгалтерии.Хозрасчетный.Обороты(
			|			&ДатаНачала,
			|			&ДатаОкончания,
			|			,
			|			Счет В ИЕРАРХИИ(&Счет)) КАК Обороты";
			ЗапросСебестоимость.УстановитьПараметр("ДатаНачала", ДатаНачала);
			ЗапросСебестоимость.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
			ЗапросСебестоимость.УстановитьПараметр("Счет", СчетСебестоимость);
			ВыборкаСебестоимость = ЗапросСебестоимость.Выполнить().Выбрать();
			Если ВыборкаСебестоимость.Следующий() Тогда
				Себестоимость = ?(ВыборкаСебестоимость.Дебет = Неопределено, 0, ВыборкаСебестоимость.Дебет);
			КонецЕсли;
		КонецЕсли;

	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("revenue", Выручка);
	Результат.Вставить("cogs", Себестоимость);
	Результат.Вставить("profit", Выручка - Себестоимость);

	Возврат Результат;

КонецФункции

Процедура ДобавитьРазбивкуПоСубконто(Знач Счет, Знач Префикс, Знач ДатаНачала, Знач ДатаОкончания, МесяцДанные, ДополнительныеКлючи, ИменаДополнительныхКлючей) Экспорт

	Если Счет = Неопределено ИЛИ Счет.Пустая() Тогда
		Возврат;
	КонецЕсли;

	ЗапросСуб = Новый Запрос;
	ЗапросСуб.Текст =
	"ВЫБРАТЬ
	|	Обороты.Период КАК Период,
	|	Обороты.Субконто1 КАК ВидРасхода,
	|	Обороты.СуммаОборотДт КАК Дебет
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(
	|			&ДатаНачала,
	|			&ДатаОкончания,
	|			Месяц,
	|			Счет В ИЕРАРХИИ(&Счет),
	|			&ВидыСубконтоДт) КАК Обороты";
	ЗапросСуб.УстановитьПараметр("ДатаНачала", ДатаНачала);
	ЗапросСуб.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	ЗапросСуб.УстановитьПараметр("Счет", Счет);
	МассивВидовСубконто = Новый Массив;
	МассивВидовСубконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ПрочиеДоходыИРасходы);
	ЗапросСуб.УстановитьПараметр("ВидыСубконтоДт", МассивВидовСубконто);

	СубконтоКлючи = Новый Соответствие;

	Выборка = ЗапросСуб.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.ВидРасхода = Неопределено ИЛИ НЕ ЗначениеЗаполнено(Выборка.ВидРасхода) Тогда
			Продолжить;
		КонецЕсли;
		Субконто = Выборка.ВидРасхода;
		КлючСубконто = СубконтоКлючи.Получить(Субконто);
		Если КлючСубконто = Неопределено Тогда
			КлючСубконто = Префикс + Строка(ДополнительныеКлючи.Количество() + 1);
			СубконтоКлючи.Вставить(Субконто, КлючСубконто);
			ДополнительныеКлючи.Добавить(КлючСубконто);
			ИменаДополнительныхКлючей.Вставить(КлючСубконто, Строка(Субконто));
			Для Каждого М Из МесяцДанные Цикл
				М.Вставить(КлючСубконто, 0);
			КонецЦикла;
		КонецЕсли;

		Индекс = Месяц(Выборка.Период) - 1;
		Стр = МесяцДанные[Индекс];
		ТекущееЗначение = Стр[КлючСубконто];
		Дебет = ?(Выборка.Дебет = Неопределено, 0, Выборка.Дебет);
		Стр.Вставить(КлючСубконто, ТекущееЗначение + Дебет);
	КонецЦикла;

КонецПроцедуры

Функция ПолучитьОтчетПоМесяцам(Знач Год) Экспорт

	// Специфично для плана счетов "Бухгалтерия для Узбекистана" (Уз НСБУ) - если счета не найдены,
	// соответствующие колонки останутся нулевыми (например для другого плана счетов).
	// Полное покрытие счетов 90xx-98xx плана "Бухгалтерия для Узбекистана" (Уз НСБУ).
	// Если счет не найден в конкретном плане счетов - колонка останется нулевой.
	Счета = Новый Структура;
	Счета.Вставить("sales", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9020"));
	Счета.Вставить("fx_income", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9540"));
	Счета.Вставить("interest_income", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9530"));
	Счета.Вставить("other_income", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9590"));
	Счета.Вставить("cogs", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9120"));
	Счета.Вставить("selling_expenses", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9410"));
	Счета.Вставить("admin", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9420"));
	Счета.Вставить("other_expenses", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9430"));
	Счета.Вставить("disposal_expenses", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9431"));
	Счета.Вставить("interest_expense", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9610"));
	Счета.Вставить("fx_loss", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9620"));
	Счета.Вставить("remuneration_expense", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9640"));
	Счета.Вставить("other_fin_expenses", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9690"));
	Счета.Вставить("tax", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9810"));
	Счета.Вставить("other_taxes", ПланыСчетов.Хозрасчетный.НайтиПоКоду("9820"));
	СчетПрибыль = ПланыСчетов.Хозрасчетный.НайтиПоКоду("9910");

	// доходные статьи (сальдо по кредиту), остальные - расходные (сальдо по дебету)
	ДоходныеПоля = Новый Массив;
	ДоходныеПоля.Добавить("sales");
	ДоходныеПоля.Добавить("fx_income");
	ДоходныеПоля.Добавить("interest_income");
	ДоходныеПоля.Добавить("other_income");

	МесяцДанные = Новый Массив;
	Для Ном = 1 По 12 Цикл
		Стр = Новый Структура;
		Стр.Вставить("month", Ном);
		Для Каждого КлючНач Из Счета Цикл
			Стр.Вставить(КлючНач.Ключ, 0);
		КонецЦикла;
		МесяцДанные.Добавить(Стр);
	КонецЦикла;

	ДатаНачала = Дата(Год, 1, 1);
	ДатаОкончания = КонецМесяца(Дата(Год, 12, 1));

	Для Каждого КлючЗначение Из Счета Цикл
		Счет = КлючЗначение.Значение;
		Если Счет = Неопределено ИЛИ Счет.Пустая() Тогда
			Продолжить;
		КонецЕсли;

		Поле = КлючЗначение.Ключ;
		ЭтоДоход = (ДоходныеПоля.Найти(Поле) <> Неопределено);

		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Обороты.Период КАК Период,
		|	Обороты.СуммаОборотДт КАК Дебет,
		|	Обороты.СуммаОборотКт КАК Кредит
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Обороты(
		|			&ДатаНачала,
		|			&ДатаОкончания,
		|			Месяц,
		|			Счет В ИЕРАРХИИ(&Счет)) КАК Обороты";
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
		Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		Запрос.УстановитьПараметр("Счет", Счет);

		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Индекс = Месяц(Выборка.Период) - 1;
			Стр = МесяцДанные[Индекс];
			ТекущееЗначение = Стр[Поле];
			Дебет = ?(Выборка.Дебет = Неопределено, 0, Выборка.Дебет);
			Кредит = ?(Выборка.Кредит = Неопределено, 0, Выборка.Кредит);
			Если ЭтоДоход Тогда
				Стр.Вставить(Поле, ТекущееЗначение + Кредит);
			Иначе
				Стр.Вставить(Поле, ТекущееЗначение + Дебет);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	// Разбивка счетов 9430 "Прочие операционные расходы" и 9420 "Административные расходы" по субконто
	// (детально, как в оригинале 1С)
	ИменаДополнительныхКлючей = Новый Структура;
	ДополнительныеКлючи430 = Новый Массив;
	ДополнительныеКлючи420 = Новый Массив;
	ДобавитьРазбивкуПоСубконто(Счета.other_expenses, "sub430_", ДатаНачала, ДатаОкончания, МесяцДанные, ДополнительныеКлючи430, ИменаДополнительныхКлючей);
	ДобавитьРазбивкуПоСубконто(Счета.admin, "sub420_", ДатаНачала, ДатаОкончания, МесяцДанные, ДополнительныеКлючи420, ИменаДополнительныхКлючей);

	// "Прибыль" (9910) - это НАКОПИТЕЛЬНЫЙ остаток счета на конец каждого месяца (с начала года),
	// а не оборот за месяц - поэтому запрашивается отдельно через Остатки() на каждую дату среза.
	Для Ном = 1 По 12 Цикл
		Стр = МесяцДанные[Ном - 1];
		Прибыль = 0;
		Если СчетПрибыль <> Неопределено И НЕ СчетПрибыль.Пустая() Тогда
			КонецМесяцаДата = КонецМесяца(Дата(Год, Ном, 1)) + 86399; // 23:59:59 того же дня - иначе не попадают проводки закрытия месяца
			ЗапросОстаток = Новый Запрос;
			ЗапросОстаток.Текст =
			"ВЫБРАТЬ
			|	Остатки.СуммаОстатокДт КАК СуммаДт,
			|	Остатки.СуммаОстатокКт КАК СуммаКт
			|ИЗ
			|	РегистрБухгалтерии.Хозрасчетный.Остатки(&НаДату, Счет = &Счет) КАК Остатки";
			ЗапросОстаток.УстановитьПараметр("НаДату", КонецМесяцаДата);
			ЗапросОстаток.УстановитьПараметр("Счет", СчетПрибыль);
			ВыборкаОстаток = ЗапросОстаток.Выполнить().Выбрать();
			Если ВыборкаОстаток.Следующий() Тогда
				СуммаДт = ?(ВыборкаОстаток.СуммаДт = Неопределено, 0, ВыборкаОстаток.СуммаДт);
				СуммаКт = ?(ВыборкаОстаток.СуммаКт = Неопределено, 0, ВыборкаОстаток.СуммаКт);
				// счет "Прибыль" (9910): остаток по кредиту - накопленная прибыль (положительная),
				// остаток по дебету - накопленный убыток (отрицательная)
				Прибыль = СуммаКт - СуммаДт;
			КонецЕсли;
		КонецЕсли;
		Стр.Вставить("profit", Прибыль);
		Стр.Вставить("tax_estimate", Окр(Прибыль * 0.15, 2));
	КонецЦикла;

	// Названия колонок - реальные наименования счетов из плана счетов (как в 1С), а не перевод программиста
	ИменаКолонок = Новый Структура;
	Для Каждого КлючЗначение Из Счета Цикл
		Счет = КлючЗначение.Значение;
		Если Счет <> Неопределено И НЕ Счет.Пустая() Тогда
			ИменаКолонок.Вставить(КлючЗначение.Ключ, Счет.Код + " " + Счет.Наименование);
		КонецЕсли;
	КонецЦикла;
	Если СчетПрибыль <> Неопределено И НЕ СчетПрибыль.Пустая() Тогда
		ИменаКолонок.Вставить("profit", СчетПрибыль.Код + " " + СчетПрибыль.Наименование);
	КонецЕсли;
	Для Каждого КлючИмя Из ИменаДополнительныхКлючей Цикл
		ИменаКолонок.Вставить(КлючИмя.Ключ, КлючИмя.Значение);
	КонецЦикла;

	// Порядок колонок для таблицы: "other_expenses"/"admin" заменяются детальной разбивкой по субконто, если она есть
	КлючиДляТаблицы = Новый Массив;
	Для Каждого КлючЗначение Из Счета Цикл
		Если КлючЗначение.Ключ = "other_expenses" И ДополнительныеКлючи430.Количество() > 0 Тогда
			Для Каждого ДопКлюч Из ДополнительныеКлючи430 Цикл
				КлючиДляТаблицы.Добавить(ДопКлюч);
			КонецЦикла;
		ИначеЕсли КлючЗначение.Ключ = "admin" И ДополнительныеКлючи420.Количество() > 0 Тогда
			Для Каждого ДопКлюч Из ДополнительныеКлючи420 Цикл
				КлючиДляТаблицы.Добавить(ДопКлюч);
			КонецЦикла;
		Иначе
			КлючиДляТаблицы.Добавить(КлючЗначение.Ключ);
		КонецЕсли;
	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("year", Год);
	Результат.Вставить("months", МесяцДанные);
	Результат.Вставить("column_names", ИменаКолонок);
	Результат.Вставить("flow_keys", КлючиДляТаблицы);

	Возврат Результат;

КонецФункции

Функция ПолучитьБанкХаракати(Знач ДатаНачала, Знач ДатаОкончания) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Обороты.Период КАК День,
	|	Обороты.Счет.Код КАК Код,
	|	Обороты.СуммаОборотДт КАК Дебет,
	|	Обороты.СуммаОборотКт КАК Кредит
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(&ДатаНачала, &ДатаОкончания, День, ) КАК Обороты
	|
	|УПОРЯДОЧИТЬ ПО
	|	День";

	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

	// Bank/kassa hisoblari - schet kodi "50" yoki "51" bilan boshlanadi
	ПоДням = Новый Соответствие;
	ТартибКунлар = Новый Массив;
	ИтогоПриход = 0;
	ИтогоРасход = 0;

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Лев(Выборка.Код, 2) <> "50" И Лев(Выборка.Код, 2) <> "51" Тогда
			Продолжить;
		КонецЕсли;

		КлючДня = Формат(Выборка.День, "ДФ=yyyy-MM-dd");
		Если ПоДням.Получить(КлючДня) = Неопределено Тогда
			ЗаписьДня = Новый Структура("date, inflow, outflow", КлючДня, 0, 0);
			ПоДням.Вставить(КлючДня, ЗаписьДня);
			ТартибКунлар.Добавить(КлючДня);
		Иначе
			ЗаписьДня = ПоДням.Получить(КлючДня);
		КонецЕсли;

		ЗаписьДня.inflow = ЗаписьДня.inflow + Выборка.Дебет;
		ЗаписьДня.outflow = ЗаписьДня.outflow + Выборка.Кредит;
		ИтогоПриход = ИтогоПриход + Выборка.Дебет;
		ИтогоРасход = ИтогоРасход + Выборка.Кредит;
	КонецЦикла;

	Дни = Новый Массив;
	Для Каждого Ключ Из ТартибКунлар Цикл
		Дни.Добавить(ПоДням.Получить(Ключ));
	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("date_from", Формат(ДатаНачала, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("date_to", Формат(ДатаОкончания, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("total_inflow", ИтогоПриход);
	Результат.Вставить("total_outflow", ИтогоРасход);
	Результат.Вставить("days", Дни);

	Возврат Результат;

КонецФункции

Функция ПолучитьОстатки(Знач НаДату, Знач Склад = Неопределено, Знач Товар = Неопределено) Экспорт

	Остатки = Новый Массив;

	Результат = Новый Структура;
	Результат.Вставить("on_date", Формат(НаДату, "ДФ=yyyy-MM-dd"));
	Результат.Вставить("warehouse", Склад);
	Результат.Вставить("item", Товар);
	Результат.Вставить("balances", Остатки);

	Возврат Результат;

КонецФункции
